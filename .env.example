# Z.ai API (used for OCR and question parsing)
Z_API_KEY=
Z_API_MODEL="glm-5.1"

# MinerU API (Precision Extract API)
MINERU_BEARER_TOKEN=

# PDF Parser provider: "zai" or "mineru"
PDF_PARSER_PROVIDER=mineru

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION="us-east-1"
S3_EXAMPAPERS_MAIN_BUCKET="examapapers"
S3_EXAMPAPERS_IMAGES_BUCKET="exampapel-images-bucket2025"

# NocoDB integration (optional — leave blank to use S3 manifest only)
NOCODB_URL=
NOCODB_API_KEY=
NOCODB_TABLE=processed_exams

# Parallel processing
MAX_WORKERS=4

# S3 layout — Main bucket (examapapers)
# ┌── inbox/<institution>/*.pdf          ← Drop raw PDFs here
# ├── staging/<institution>/*.md         ← Markdown (Phase 1 output → Phase 2 input)
# ├── output/<institution>/<exam_name>/  ← Final structured JSON + markdown
# ├── archive/<institution>/             ← Successfully processed inputs
# │   ├── pdfs/*.pdf                     ← Archived original PDFs
# │   └── markdown/*.md                  ← Archived processed markdown
# ├── failed/<institution>/*             ← Failed files
# └── .system/manifest.json              ← Processing history
#
# S3 layout — Images bucket (exampapel-images-bucket2025)
# └── <institution>/<exam_name>/         ← Re-hosted exam paper images
